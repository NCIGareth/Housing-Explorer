generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  createdAt     DateTime      @default(now())
  savedSearches SavedSearch[]
  alerts        Alert[]
}

model HistoricalMetric {
  id         String   @id @default(cuid())
  source     String
  metric     String
  geography  String
  period     String
  value      Float
  unit       String
  createdAt  DateTime @default(now())

  @@index([metric, geography, period])
}

model ListingCurrent {
  id             String   @id @default(cuid())
  externalId     String
  source         String
  title          String
  county         String
  locality       String?
  eircode        String?
  askingPriceEur Int
  beds           Int?
  baths          Int?
  propertyType   String?
  listedAt       DateTime
  listingUrl     String
  latitude       Float?
  longitude      Float?
  isActive       Boolean  @default(true)
  lastSeenAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([source, externalId])
  @@index([county, askingPriceEur, isActive])
  @@index([county, askingPriceEur, beds, isActive])
  @@index([isActive])
  @@index([listedAt])
}

model SavedSearch {
  id          String   @id @default(cuid())
  userId      String
  name        String
  county      String?
  minPriceEur Int?
  maxPriceEur Int?
  minBeds     Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts      Alert[]
}

model Alert {
  id             String      @id @default(cuid())
  userId         String
  savedSearchId  String?
  type           AlertType
  enabled        Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  lastTriggeredAt DateTime?
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedSearch    SavedSearch? @relation(fields: [savedSearchId], references: [id], onDelete: SetNull)
}

model IngestionRun {
  id          String   @id @default(cuid())
  source      String
  status      RunStatus
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  rowsRead    Int      @default(0)
  rowsUpserted Int     @default(0)
  error       String?
}

model PropertySale {
  id                      String   @id @default(cuid())
  sourceKey               String   @unique
  saleDate                DateTime
  address                 String
  county                  String
  eircode                 String?
  priceEur                Int
  notFullMarketPrice      Boolean
  vatExclusive            Boolean
  descriptionOfProperty   String
  propertySizeDescription String?
  latitude                Float?
  longitude               Float?
  createdAt               DateTime @default(now())

  @@index([county, saleDate])
  @@index([saleDate, priceEur])
}



enum AlertType {
  NEW_LISTING_MATCH
  PRICE_DROP
}

enum RunStatus {
  RUNNING
  SUCCESS
  FAILED
}
