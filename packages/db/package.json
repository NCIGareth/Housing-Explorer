{
  "name": "@housing/db",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "node ../../scripts/prisma-with-env.mjs migrate dev",
    "db:seed": "node ../../scripts/prisma-with-env.mjs db execute --file prisma/seed.sql --schema prisma/schema.prisma",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "prisma": "^5.20.0",
    "typescript": "^5.6.3"
  }
}
